
# 128. Longest Consecutive Sequence
# https://leetcode.com/problems/longest-consecutive-sequence/
#
# Time Complexity: O(n)
# Space Complexity: O(n)

from typing import List



class Solution:
    def longestConsecutive(self, nums: List[int]) -> int:
        res=0
        store=set(nums)

        for num in store:
            if num-1 not in store:
                curr,streak=num,0
            
            while curr in store:
                streak+=1
                curr+=1
            res=max(res,streak)
        return res

    